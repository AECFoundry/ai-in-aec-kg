# === LLM Provider ===
# Set ONE of these. If both are set, OpenRouter takes precedence.
#
# Option A: OpenRouter (supports all models including Google Gemini for extraction)
# Sign up at https://openrouter.ai and create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
#
# Option B: Direct OpenAI API (uses GPT-4.1-mini as fallback for extraction)
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Neo4j connection (matches docker-compose.yml defaults)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev_password_kg2026

# JWT secret for user sessions (change to any random string)
JWT_SECRET=change-me-to-a-random-secret

# Frontend URL (for CORS configuration)
APP_URL=http://localhost:5173
